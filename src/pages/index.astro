---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Nav from '../components/layout/Nav';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import BeachSection from '../components/sections/BeachSection.astro';
import FeatureCard from '../components/ui/FeatureCard.astro';
import Button from '../components/ui/Button.astro';

import heroImage from '../assets/images/balcony.avif';
import workspaceImage from '../assets/images/living-room.avif';
import ebikeImage from '../assets/images/villa-ebike.webp';
import beachImage from '../assets/images/meia-praia.webp';
import lagosImage from '../assets/images/lagos.webp';
import locationImage from '../assets/images/location.avif';

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'LodgingBusiness',
  name: 'Villa Calma',
  description:
    'Luxury villa rental in Vale da Ribeira, Lagos, Algarve, Portugal. Modern comfort meets Mediterranean heritage.',
  url: 'https://villacalma.pt',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Vale da Ribeira',
    addressLocality: 'Lagos',
    addressRegion: 'Algarve',
    addressCountry: 'PT',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 37.1,
    longitude: -8.67,
  },
  amenityFeature: [
    { '@type': 'LocationFeatureSpecification', name: 'Infinity Pool', value: true },
    { '@type': 'LocationFeatureSpecification', name: "Kids' Pool", value: true },
    { '@type': 'LocationFeatureSpecification', name: 'High-speed Wi-Fi', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Smart TV', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Private Terrace', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Balcony', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Free Private Parking', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Air Conditioning', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Washer', value: true },
    { '@type': 'LocationFeatureSpecification', name: "Children's Playground", value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Self Check-In', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Lioz Limestone Floors', value: true },
    { '@type': 'LocationFeatureSpecification', name: 'Electric Bike Rental', value: true },
  ],
});
---

<Layout
  title="Luxury Villa in the Algarve"
  description="Villa Calma — a curated luxury retreat in Vale da Ribeira, Lagos. Experience the soul of the Algarve where modern minimalism meets Mediterranean warmth."
  jsonLd={jsonLd}
>
  <Nav client:load currentPath="/" transparentHero={true} />

  <main>
    <!-- Hero -->
    <Hero
      headline="The Soul of the Algarve, Rediscovered."
      subheadline="A curated retreat in Vale da Ribeira, Lagos — where slow living meets quiet luxury."
      ctaLabel="Begin Your Journey"
      ctaHref="/booking"
      image={heroImage}
      imageAlt="Villa Calma terrace at golden hour overlooking the Algarve hills"
    />

    <!-- Editorial intro -->
    <BeachSection
      eyebrow="The Villa"
      heading="Quiet Beauty at Meia Praia's Veranda"
      body="Nestled between golden cliffs and the Atlantic, Villa Calma is more than a place to stay — it's a way of being. Every detail has been considered to let you breathe, rest, and rediscover the art of slow living."
      image={heroImage}
      imageAlt="Villa Calma terrace overlooking the Algarve hills"
      ctaLabel="Explore the Space"
      ctaHref="/amenities"
      data-animate
    />

    <!-- Feature cards: Designed for Living -->
    <section class="w-full max-w-[1280px] mx-auto px-6 md:px-10 lg:px-16 pb-20 md:pb-28">
      <div class="mb-12" data-animate>
        <span class="text-label-lg text-secondary tracking-widest block mb-3">Designed for Living</span>
        <h2 class="text-headline-lg font-display text-primary">Modern Comfort, Timeless Style.</h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6" data-animate-group>
        <FeatureCard
          image={workspaceImage}
          imageAlt="Minimalist workspace with infinity pool view"
          badge="WORKSPACE"
          title="Remote Work Ready"
          body="Stay connected effortlessly. High-speed internet paired with a dedicated, minimalist workspace offering inspiring views of the Algarve hills and the infinity pool."
          tags={['High-Speed Internet', 'Dedicated Desk']}
          data-animate-card
        />
        <FeatureCard
          image={ebikeImage}
          imageAlt="Premium e-bike against Portuguese whitewashed wall with bougainvillea"
          badge="MOBILITY"
          title="Sustainable Mobility"
          body="Explore the beauty of Lagos at your own pace. Our premium e-bike rental service provides an eco-friendly and effortless way to navigate the coastline and historic centre."
          tags={['Premium E-Bikes']}
          data-animate-card
        />
      </div>
    </section>

    <!-- Full-bleed beach discovery -->
    <BeachSection
      eyebrow="Discover the Golden Coast"
      heading="Meia Praia"
      body="Three kilometres of unspoilt sand, where the Atlantic meets the Algarve's golden cliffs. Your private beach, just minutes from the villa."
      image={beachImage}
      imageAlt="Aerial view of Meia Praia beach at golden hour"
      fullBleed={true}
      data-animate
    />

    <!-- Meia Praia editorial -->
    <BeachSection
      eyebrow="Your Neighbourhood"
      heading="Between the Cliffs and the Sea"
      body="Lagos is one of Portugal's most cherished coastal towns — a place where ancient fortified walls meet vibrant local culture. From the villa, the town's cafés, markets, and hidden beaches are all within easy reach."
      image={lagosImage}
      imageAlt="Lagos town with cliffs and turquoise water"
      imagePosition="left"
      data-animate
    />

    <!-- Location / Map -->
    <section class="w-full max-w-[1280px] mx-auto px-6 md:px-10 lg:px-16 py-20 md:py-28">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="flex flex-col gap-5" data-animate>
          <span class="text-label-lg text-secondary tracking-widest">Location</span>
          <h2 class="text-headline-lg font-display text-primary">Nestled in the Heart of the Western Algarve</h2>
          <p class="font-body text-on-surface-var text-lg leading-relaxed">
            Situated in the serene Vale da Ribeira, Villa Calma offers a perfect balance between the historic charm of Lagos and the quiet, authentic beauty of Mexilhoeira Grande.
          </p>
          <p class="font-body text-on-surface-var text-lg leading-relaxed">
            Experience the best of the Golden Coast with Meia Praia just a 10-minute drive away. Our location provides effortless access to the A22, making it an ideal base for exploring the hidden coves and vibrant culture of the Algarve.
          </p>
          <ul class="flex flex-col gap-4 mt-2">
            <li class="flex items-center gap-3 font-body text-on-surface-var">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-secondary flex-shrink-0"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7.1 12.5 7.4 12.8a.8.8 0 0 0 1.1 0C12.9 22.5 20 15.4 20 10a8 8 0 0 0-8-8z"/></svg>
              10 mins to Meia Praia
            </li>
            <li class="flex items-center gap-3 font-body text-on-surface-var">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-secondary flex-shrink-0"><rect x="2" y="6" width="20" height="12" rx="2"/><path d="M10 10h2a2 2 0 1 1 0 4h-2V10z"/><path d="M10 10v8"/></svg>
              5 mins to A22 Highway
            </li>
            <li class="flex items-center gap-3 font-body text-on-surface-var">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" class="text-secondary flex-shrink-0"><rect x="3" y="10" width="18" height="3" rx="1"/><path d="M3 13v8M21 13v8M7 13v8M17 13v8M3 18h18"/></svg>
              15 mins to Lagos Old Town
            </li>
          </ul>
        </div>

        <div class="relative overflow-hidden rounded-2xl bg-surface-low flex items-center justify-center min-h-[420px]" data-animate>
            <Image
              src={locationImage}
              alt="Villa location"
              width={600}
              height={600}
              loading="lazy"
              class="object-cover"
            />
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="w-full bg-surface-container py-20 md:py-28">
      <div class="max-w-[1280px] mx-auto px-6 md:px-10 lg:px-16 text-center" data-animate>
        <span class="text-label-lg text-secondary tracking-widest block mb-4">Reserve Your Stay</span>
        <h2 class="text-headline-lg font-display text-primary mb-6 max-w-lg mx-auto">
          Ready to Experience Slow Living?
        </h2>
        <p class="font-body text-on-surface-var text-lg leading-relaxed mb-10 max-w-md mx-auto">
          Choose your preferred platform to secure your dates at Villa Calma.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button href="/booking" variant="secondary">Book on Airbnb</Button>
          <Button href="/booking" variant="outline">Book on Booking.com</Button>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
