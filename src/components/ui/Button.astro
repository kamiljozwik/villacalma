---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md';
  external?: boolean;
  class?: string;
  type?: 'button' | 'submit';
  id?: string;
}

const {
  href,
  variant = 'primary',
  size = 'md',
  external = false,
  class: className = '',
  type = 'button',
  id,
} = Astro.props;

const base =
  'inline-flex items-center justify-center font-body font-bold text-label-lg tracking-widest transition-all duration-200 cursor-pointer border-2';

const sizes = {
  sm: 'px-6 py-3 text-xs',
  md: 'px-8 py-4 text-sm',
};

const variants = {
  primary: 'bg-primary text-on-primary border-primary hover:bg-primary-container hover:border-primary-container',
  secondary: 'bg-secondary text-on-secondary border-secondary hover:opacity-90',
  outline: 'bg-transparent text-primary border-primary hover:bg-primary hover:text-on-primary',
};

const classes = [base, sizes[size], variants[variant], 'rounded-sm', className].join(' ');
---

{
  href ? (
    <a
      href={href}
      id={id}
      class={classes}
      {...external ? { target: '_blank', rel: 'noopener noreferrer' } : {}}
    >
      <slot />
    </a>
  ) : (
    <button type={type} id={id} class={classes}>
      <slot />
    </button>
  )
}
