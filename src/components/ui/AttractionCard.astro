---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  badge: string;
  category?: 'beach' | 'nature' | 'culture' | 'adventure';
  title: string;
  image: ImageMetadata;
  distance: string;
  body: string;
  tags?: string[];
  'data-animate-card'?: string | boolean;
}

const {
  badge,
  category = 'nature',
  title,
  image,
  distance,
  body,
  tags = [],
  'data-animate-card': dataAnimateCard,
} = Astro.props;

const gradients: Record<string, string> = {
  beach:     'linear-gradient(145deg, #6ac4da 0%, #aadcec 40%, #e8d4a0 100%)',
  nature:    'linear-gradient(145deg, #c08020 0%, #daa840 40%, #f0d890 100%)',
  culture:   'linear-gradient(145deg, #904828 0%, #c07848 40%, #e8bea0 100%)',
  adventure: 'linear-gradient(145deg, #284860 0%, #507088 40%, #90afc0 100%)',
};
---

<article
  class="flex flex-col bg-surface rounded-lg overflow-hidden group hover:shadow-[0_8px_32px_rgba(0,30,51,0.1)] transition-shadow duration-300"
  data-animate-card={dataAnimateCard !== undefined ? '' : undefined}
>
  <!-- Placeholder image — replace outer div with <Image> when photos are ready -->
              <Image
              src={image}
              alt={title}
              width={600}
              height={600}
              loading="lazy"
              class="object-cover"
            />

  <div class="flex flex-col gap-3 p-6">
    <h3 class="text-headline-md font-display text-primary">{title}</h3>
    <p class="font-body text-on-surface-var text-base leading-relaxed">{body}</p>

    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-1">
        {tags.map((tag) => (
          <span class="text-label-sm text-on-surface-var bg-surface-high px-3 py-1.5 rounded-sm">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</article>
