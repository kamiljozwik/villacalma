---
interface Props {
  icon: string;
  title: string;
  body: string;
  'data-animate-card'?: string | boolean;
}

const { icon, title, body, 'data-animate-card': dataAnimateCard } = Astro.props;
---

<div
  class="flex flex-col items-center text-center gap-4 p-6"
  data-animate-card={dataAnimateCard}
>
  <div class="w-12 h-12 flex items-center justify-center text-secondary" set:html={icon} />
  <h3 class="font-display text-primary font-medium text-lg">{title}</h3>
  <p class="font-body text-on-surface-var text-base leading-relaxed">{body}</p>
</div>
