---
import Button from './Button.astro';

interface Props {
  platform: 'airbnb' | 'booking';
  title: string;
  body: string;
  href: string;
  ctaLabel: string;
  'data-animate-card'?: string;
}

const { platform, title, body, href, ctaLabel, 'data-animate-card': dataAnimateCard } = Astro.props;

const platformStyles = {
  airbnb: { accent: '#FF5A5F', label: 'airbnb' },
  booking: { accent: '#003580', label: 'Booking.com' },
};

const style = platformStyles[platform];
---

<article
  class="flex flex-col bg-white border border-outline-var rounded-lg overflow-hidden"
  data-animate-card={dataAnimateCard}
>
  <div class="px-8 pt-8 pb-4">
    <!-- Platform wordmark -->
    <div class="mb-6">
      {platform === 'airbnb' ? (
        <span class="font-body font-bold text-2xl" style={`color: ${style.accent}`}>airbnb</span>
      ) : (
        <span class="font-body font-bold text-2xl" style={`color: ${style.accent}`}>Booking.com</span>
      )}
    </div>
    <h3 class="text-headline-md font-display text-primary mb-4">{title}</h3>
    <p class="font-body text-on-surface-var text-base leading-relaxed">{body}</p>
  </div>

  <div class="px-8 pb-8 mt-auto pt-6">
    <Button href={href} variant="primary" external class="w-full justify-center">
      {ctaLabel}
    </Button>
  </div>
</article>
