---
interface Props {
  icon: string;
  title: string;
  description?: string;
  'data-animate-card'?: string | boolean | boolean;
}

const { icon, title, description, 'data-animate-card': dataAnimateCard } = Astro.props;
---

<div
  class="flex flex-col gap-3 p-6 bg-surface-low border border-outline-var rounded-lg hover:shadow-lg transition-shadow duration-300"
  data-animate-card={dataAnimateCard}
>
  <div class="w-10 h-10 flex items-center justify-center text-secondary" set:html={icon} />
  <h3 class="text-label-lg text-primary font-display">{title}</h3>
  {description && (
    <p class="font-body text-sm text-on-surface-var leading-relaxed">{description}</p>
  )}
</div>
