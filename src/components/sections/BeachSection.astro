---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  eyebrow?: string;
  heading: string;
  body: string;
  image: ImageMetadata;
  imageAlt: string;
  imagePosition?: 'left' | 'right';
  fullBleed?: boolean;
  'data-animate'?: string;
}

const {
  eyebrow,
  heading,
  body,
  image,
  imageAlt,
  imagePosition = 'right',
  fullBleed = false,
  'data-animate': dataAnimate,
} = Astro.props;

const textOrder = imagePosition === 'right' ? 'order-1' : 'order-2';
const imageOrder = imagePosition === 'right' ? 'order-2' : 'order-1';
---

{fullBleed ? (
  <section class="relative w-full aspect-[16/9] md:aspect-[21/9] overflow-hidden" data-animate={dataAnimate}>
    <Image
      src={image}
      alt={imageAlt}
      width={1920}
      height={900}
      loading="lazy"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-primary/60 via-transparent to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-8 md:p-16 max-w-[1280px] mx-auto">
      {eyebrow && <p class="text-label-lg text-secondary mb-2">{eyebrow}</p>}
      <h2 class="text-headline-lg font-display text-white mb-3">{heading}</h2>
      <p class="font-body text-white/80 text-lg max-w-xl leading-relaxed">{body}</p>
    </div>
  </section>
) : (
  <section class="w-full max-w-[1280px] mx-auto px-6 md:px-10 lg:px-16 py-section" data-animate={dataAnimate}>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <div class={`flex flex-col gap-5 ${textOrder}`}>
        {eyebrow && <span class="text-label-lg text-secondary tracking-widest">{eyebrow}</span>}
        <h2 class="text-headline-lg font-display text-primary">{heading}</h2>
        <p class="font-body text-on-surface-var text-lg leading-relaxed">{body}</p>
      </div>
      <div class={`${imageOrder} overflow-hidden rounded-lg`}>
        <Image
          src={image}
          alt={imageAlt}
          width={800}
          height={600}
          loading="lazy"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
        />
      </div>
    </div>
  </section>
)}
